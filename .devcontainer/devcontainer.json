{
  "name": "my-portfolio",
  "image": "mcr.microsoft.com/devcontainers/python:3.11-bookworm",
  "waitFor": "updateContentCommand",
  "updateContentCommand": "pip install -r requirements.txt",
  "forwardPorts": [
    8501,
    5000,
    3000
  ],
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "files.exclude": {
          "/pycache": true,
          "**/__pycache__": true
        },
        "chat.newSession.defaultMode": "agent",
        "chat.planAgent.defaultModel": "gpt-5.4-nano (azure)",
        "inlineChat.defaultModel": "gpt-5.4-nano (azure)",
        "chat.exploreAgent.defaultModel": "gpt-5.4-nano (azure)",
        "github.copilot.nextEditSuggestions.preferredModel": "gpt-5.4-nano (azure)",
        "github.copilot.selectedCompletionModel": "gpt-5.4-nano (azure)",
        "github.copilot.chat.askAgent.model": "gpt-5.4-nano (azure)",
        "github.copilot.chat.executionSubagent.model": "gpt-5.4-nano (azure)",
        "github.copilot.chat.exploreAgent.model": "gpt-5.4-nano (azure)",
        "github.copilot.chat.implementAgent.model": "gpt-5.4-nano (azure)",
        "chat.utilityModel": "azure/",
        "chat.utilitySmallModel": "azure/"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "GitHub.copilot-chat",
        "GitHub.copilot",
        "esbenp.prettier-vscode",
        "yzhang.markdown-all-in-one",
        "shd101wyy.markdown-preview-enhanced"
      ]
    }
  }
}